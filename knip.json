{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "next.config.ts",
    "middleware.ts"
  ],
  "project": [
    "**/*.{ts,tsx,js,jsx}"
  ],
  "ignore": [
    "styles/**",
    "**/*.scss",
    "**/*.css",
    "public/**",
    ".next/**",
    "node_modules/**"
  ],
  "ignoreDependencies": [],
  "ignoreExportsUsedInFile": true
}
